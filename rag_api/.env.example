# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  RAG API — environment variables                                           ║
# ║  Copy this file to `.env` and fill in the values.                          ║
# ║  Vars marked [REQUIRED] must be set or the app will not start.             ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# ─── GENERAL ─────────────────────────────────────────────────────────────────
# 'development' turns Django DEBUG on; use 'production' when deployed.
ENVIRONMENT=development

# ─── DOCKER ──────────────────────────────────────────────────────────────────
# Container restart policy (read by docker-compose): 'no' (dev) | 'always' (prod)
RESTART_POLICY=no

# ─── DJANGO CORE ─────────────────────────────────────────────────────────────
# [REQUIRED] Long random string.
SECRET_KEY="change-me-to-a-long-random-secret"

# Comma-separated hostnames allowed to serve the API ('*' = any). Default: *
ALLOWED_HOSTS=*

# ─── CALLBACK AUTH ───────────────────────────────────────────────────────────
# [REQUIRED] Shared secret authenticating callbacks with evaluator_api.
# Must match the same value configured on the evaluator_api side.
QIP_CALLBACK_SECRET="change-me"

# ─── HUGGING FACE ────────────────────────────────────────────────────────────
# [REQUIRED] Token to download the embedding model (config.yaml → embeddings.model_name).
# Create one (read access is enough) at https://huggingface.co/settings/tokens
HF_TOKEN="hf_xxx"

# ─── LLM PROVIDER KEY ────────────────────────────────────────────────────────
# Set the key for the provider chosen by `wrapper:` in config/config.yaml.
# The shipped config uses OpenAI, so fill in OPENAI_API_KEY below.
# Each provider takes a single-key var OR a comma-separated rotation var;
# when both are present the rotation (…_KEYS) var is used.

# ── OpenAI (active in the default config) ────────────────────────────────────
OPENAI_API_KEY="sk-xxx"
# Rotate across multiple keys (optional, takes precedence over the single key):
# OPENAI_API_KEYS="sk-one,sk-two,sk-three"

# ── Groq (only if you set wrapper: "groq") ───────────────────────────────────
# GROQ_API_KEY="gsk_xxx"
# Rotation (optional, takes precedence over the single key):
# GROQ_API_KEYS="gsk_one,gsk_two"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Allow any origin (handy in dev). Set False in production. Default: False
CORS_ALLOW_ALL_ORIGINS=True
# Used only when CORS_ALLOW_ALL_ORIGINS=False — comma-separated allowed origins:
CORS_ALLOWED_ORIGINS=
