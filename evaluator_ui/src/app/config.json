{
  "version": "2.0.0",
  "organizationData": {
    "acronym": "EEDA",
    "name": "EEDA"
  },
  "registerLink": "https://eubbc-digital.upb.edu/booking/access",
  "time": {
    "notificationPolling": 3,
    "evaluationPolling": 5
  },
  "api": {
    "baseUrl": "http://localhost:8000/api/",
    "users": {
      "login": "users/auth/login/"
    },
    "evaluation": {
      "create": "evaluations/create_evaluation/",
      "evaluate": "evaluations/evaluate/",
      "verifyMetadata": "evaluations/verify_metadata/",
      "list": "evaluations/list_evaluations/",
      "detailModule": "evaluations/evaluation_detail/module/{id}/",
      "detailScan": "evaluations/evaluation_detail/scan/{id}/",
      "statusModule": "evaluations/evaluation_status/module/{id}/",
      "statusScan": "evaluations/evaluation_status/scan/{id}/",
      "idsList": "evaluations/evaluation_ids/{id}/",
      "linkModule": "evaluations/link_module/{id}/",
      "modulesList": "evaluations/modules/{email}/",
      "basicInformation": "evaluations/basic_information/{id}/"
    },
    "notifications": {
      "read": "notifications/read_message/",
      "mailbox": "notifications/user_mailbox/{email}/",
      "unreadQuantity": "notifications/notifications_unread/{email}/"
    },
    "peerReview": {
      "reviews": "reviews/reviews/{id}/",
      "scansInfo": "reviews/scans_info/{id}/",
      "reviewDetail": "reviews/review_detail/{reviewerId}/{scanId}"
    },
    "selfAssessment": {
      "results": "evaluations/self_assessment/{id}/results/",
      "status": "evaluations/self_assessment/{id}/status/"
    },
    "extra": {
      "download": "evaluations/download_pdf/{id}/",
      "downloadBadge": "evaluations/self_assessment/{id}/certificate/"
    }
  }
}