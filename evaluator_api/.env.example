# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  Evaluator API — environment variables                                     ║
# ║  Copy this file to `.env` and fill in the values.                          ║
# ║  Vars marked [REQUIRED] must be set or the app will not start.             ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# ─── GENERAL ─────────────────────────────────────────────────────────────────
# 'development' turns Django DEBUG on; use 'production' when deployed.
ENVIRONMENT=development

# ─── DOCKER ──────────────────────────────────────────────────────────────────
# Container restart policy (read by docker-compose): 'no' (dev) | 'always' (prod)
RESTART_POLICY=no
# Host path mounted to /app/staticfiles (read by docker-compose).
STATIC_VOLUME_PATH=./staticfiles

# ─── DJANGO CORE ─────────────────────────────────────────────────────────────
# [REQUIRED] Long random string.
SECRET_KEY="change-me-to-a-long-random-secret"
# Comma-separated hostnames allowed to serve the API ('*' = any). Default: *
ALLOWED_HOSTS=*
# Base path served for static files. Default: /evaluator/api/static/
STATIC_URL=/evaluator/api/static/

# ─── DATABASE (PostgreSQL) ───────────────────────────────────────────────────
# [REQUIRED] Database name, user, and password.
POSTGRES_DB=qip_evaluator
POSTGRES_USER=postgres
POSTGRES_PASSWORD="change-me"
# Host and port. Defaults: db / 5432 ('db' = the compose service name).
DB_HOST=db
DB_PORT=5432

# ─── EXTERNAL URLs ───────────────────────────────────────────────────────────
# Public URL where THIS API is reachable — used to build the callback URLs the
# RAG service calls back to. Default: http://host.docker.internal:8004/
PUBLIC_BASE_URL=http://host.docker.internal:8004/
# [REQUIRED] External identity-provider endpoints for login / current-user. 
# Default project for this project is EUBBC Book4RLab Project
EXTERNAL_LOGIN_API_URL=https://eubbc-digital.upb.edu/booking/api/users/token/
EXTERNAL_AUTH_ME_URL=https://eubbc-digital.upb.edu/booking/api/users/me/

# ─── RAG SERVICE ─────────────────────────────────────────────────────────────
# [REQUIRED] Base URL of the rag_api service.
RAG_BASE_URL=http://host.docker.internal:8005/
# [REQUIRED] Shared secret authenticating callbacks from rag_api.
# Must hold the SAME value as QIP_CALLBACK_SECRET in the rag_api .env.
RAG_CALLBACK_SECRET="change-me"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Allow any origin (handy in dev). Set False in production. Default: False
CORS_ALLOW_ALL_ORIGINS=True
# Used only when CORS_ALLOW_ALL_ORIGINS=False — comma-separated allowed origins:
CORS_ALLOWED_ORIGINS=

# ─── EMAIL ───────────────────────────────────────────────────────────────────
# Gmail SMTP credentials — used ONLY when ENVIRONMENT=production
# (dev prints emails to the console). [REQUIRED in production]
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD="app-password"
# [REQUIRED] Address that receives Django admin error reports.
ADMIN_EMAIL=admin@example.com
